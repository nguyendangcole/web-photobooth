# Database Configuration
DB_HOST=localhost
DB_NAME=photobooth_db
DB_USER=photobooth
DB_PASS=photobooth123

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
FB_APP_ID=your_facebook_app_id_here
FB_APP_SECRET=your_facebook_app_secret_here

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com/photobooth

# Email Configuration (PHPMailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=Photobooth App

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/
PHOTOBOOK_PATH=public/photobook/

# Security
SESSION_LIFETIME=3600
CSRF_TOKEN_LENGTH=32

# Redis Cache (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=error
LOG_PATH=logs/
